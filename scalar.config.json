{
  "$schema": "https://cdn.scalar.com/schema/scalar-config-next.json",
  "scalar": "2.0.0",
  "info": {
    "title": "stamp-web",
    "description": "Documentation for stamp-web"
  },
  "siteConfig": {
    "subdomain": "stamp-web"
  },
  "navigation": {
    "routes": {
      "/": {
        "type": "group",
        "title": "Documentation",
        "children": {
          "/": {
            "title": "Quickstart",
            "type": "page",
            "filepath": "docs-quickstart.md",
            "showInSidebar": true
          },
          "/openapi": {
            "title": "Scalar Galaxy",
            "type": "openapi",
            "mode": "flat",
            "singlePage": false,
            "showInSidebar": true,
            "filepath": "docs-openapi.json"
          }
        }
      }
    }
  }
}